<Window x:Class="LibraryManagementSystem.Views.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagementSystem.Views"
        mc:Ignorable="d"
        Background="#0F172A"
        Title="AddBookWindow"
        Height="700"
        Width="900">

    <Grid>

        <Border Width="500"
                Padding="30"
                CornerRadius="15"
                Background="#1E293B"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel>

                <TextBlock Text="Add New Book"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,25"
                           HorizontalAlignment="Center"/>

                <!-- BOOK TITLE -->

                <TextBlock Text="Book Title"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,10,0,5"/>

                <TextBox x:Name="txtTitle"
                         Height="40"
                         Background="#334155"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="10"
                         FontSize="14"
                         Margin="0,0,0,10"/>

                <!-- AUTHOR -->

                <TextBlock Text="Author"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,10,0,5"/>

                <TextBox x:Name="txtAuthor"
                         Height="40"
                         Background="#334155"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="10"
                         FontSize="14"
                         Margin="0,0,0,10"/>

                <!-- ISBN -->

                <TextBlock Text="ISBN"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,10,0,5"/>

                <TextBox x:Name="txtISBN"
                         Height="40"
                         Background="#334155"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="10"
                         FontSize="14"
                         Margin="0,0,0,10"/>

                <!-- CATEGORY -->

                <TextBlock Text="Category"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,10,0,5"/>

                <TextBox x:Name="txtCategory"
                         Height="40"
                         Background="#334155"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="10"
                         FontSize="14"
                         Margin="0,0,0,10"/>

                <!-- STOCK -->

                <TextBlock Text="Stock"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,10,0,5"/>

                <TextBox x:Name="txtStock"
                         Height="40"
                         Background="#334155"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="10"
                         FontSize="14"
                         Margin="0,0,0,20"/>

                <!-- BUTTON -->

                <Button x:Name="btnAddBook"
                        Content="ADD BOOK"
                        Height="45"
                        Background="#31A2FF"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        FontSize="15"
                        Cursor="Hand"
                        Click="btnAddBook_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>