<Window x:Class="LibraryManagementSystem.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagementSystem.Views"
        mc:Ignorable="d"
        Background="#0F172A"
        Title="DashboardWindow"
        Height="450"
        Width="930">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="#1E293B"
                BorderBrush="#334155"
                BorderThickness="0,0,1,0">

            <StackPanel>

                <TextBlock Text="LIBRARY"
                           Foreground="#F8FAFC"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="20,30,20,30"/>

                <Button x:Name="btnDashboard"
                        Content="Dashboard"
                        Height="45"
                        Margin="15,5"
                        Background="#334155"
                        Foreground="White"
                        FontSize="15"
                        Cursor="Hand"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"/>

                <Button x:Name="btnBooks"
                        Content="Books"
                        Height="45"
                        Margin="15,5"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="15"
                        Cursor="Hand"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"/>

                <Button x:Name="btnBorrowed_Books"
                        Content="My Books"
                        Height="45"
                        Margin="15,5"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="15"
                        Cursor="Hand"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"/>

                <Button x:Name="btnHistory"
                        Content="History"
                        Height="45"
                        Margin="15,5"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="15"
                        Cursor="Hand"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"/>

                <Button x:Name="btnLogout"
                        Content="Logout"
                        Height="45"
                        Margin="15,5"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="15"
                        Cursor="Hand"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"/>

            </StackPanel>

        </Border>

        <!-- MAIN CONTENT -->

        <Border Grid.Column="1"
                Background="#0F172A"
                Padding="30">

            <StackPanel>

                <TextBlock Text="Welcome Back"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           Margin="20"/>
                <WrapPanel>
                    <Border Background="#1E293B"
                            CornerRadius="15"
                            Padding="20"
                            Margin="0,20,20,0"
                            Width="260"
                            Height="140">
                        <StackPanel>
                            <TextBlock Text="Total Books:" Foreground="White" FontSize="40" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="128" Foreground="White" FontSize="32" FontWeight="Bold"/>

                        </StackPanel>
                    </Border>
                    <Border Background="#1E293B"
                            CornerRadius="15"
                            Padding="20"
                            Margin="0,20,20,0"
                            Width="350"
                            Height="140">

                        <StackPanel>
                            <TextBlock Text="Borrowed Books" Foreground="White" FontSize="40" FontWeight="Bold" Margin="0,0,0,10"/>
                            <TextBlock Text="24" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

            </StackPanel>

        </Border>

    </Grid>

</Window>   