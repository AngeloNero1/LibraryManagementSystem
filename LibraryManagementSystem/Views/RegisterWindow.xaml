<Window x:Class="LibraryManagementSystem.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagementSystem.Views"
        mc:Ignorable="d"
        Background="#0F172A"
        Title="RegisterWindow" Height="450" Width="800">
    <Grid>
        <Border Background="#1e293b" BorderBrush="#475569" Width="350" Height="400" HorizontalAlignment="center" VerticalAlignment="Center" CornerRadius="13" Padding="30">
            <StackPanel>
                <TextBlock Text="Register" Foreground="#F8FAFC" FontWeight="Bold" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Username" Foreground="White" FontSize="14"/>
                <TextBox x:Name="txtusername"  Height="35" Background="#334155" Foreground="White" BorderThickness="0" Margin="0,5,0,20" Padding="10"/>

                <TextBlock Text="Password" Foreground="White" FontSize="14"/>
                <PasswordBox x:Name="txtPassword" Height="35" Background="#334155" Foreground="White" BorderThickness="0" Margin="0,5,0,10" Padding="10"/>

                <TextBlock Text="Confirm Password" Foreground="White" FontSize="14"/>
                <PasswordBox x:Name="txtPassword2" Height="35" Background="#334155" Foreground="White" BorderThickness="0" Margin="0,5,0,10" Padding="10"/>

                <Button Content="REGISTER" x:Name="btnRegister" Height="40" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,10,0,0" Background="#31a2ff" Cursor="Hand" Click="btnRegister_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>