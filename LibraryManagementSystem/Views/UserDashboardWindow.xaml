<Window x:Class="LibraryManagementSystem.Views.UserDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#0F172A"
        Title="UserDashboardWindow"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="#1E293B">

            <StackPanel>

                <TextBlock Text="LIBRARY USER"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="20,30"/>

                <Button x:Name="btnDashboard"
                        Content="Dashboard"
                        Height="45"
                        Margin="15,5"
                        Background="#334155"
                        Foreground="White"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"
                        Click="btnDashboard_Click"/>

                <Button x:Name="btnBooks"
                        Content="Books"
                        Height="45"
                        Margin="15,5"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"
                        Click="btnBooks_Click"/>

                <Button x:Name="btnBorrowedBooks"
                        Content="My Borrowed Books"
                        Height="45"
                        Margin="15,5"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"
                        Click="btnBorrowedBooks_Click"/>

                <Button x:Name="btnLogout"
                        Content="Logout"
                        Height="45"
                        Margin="15,40,15,5"
                        Background="#7F1D1D"
                        Foreground="White"
                        BorderThickness="0"
                        HorizontalContentAlignment="Left"
                        Padding="20,0,0,0"
                        Click="btnLogout_Click"/>

            </StackPanel>

        </Border>

        <!-- MAIN CONTENT -->

        <Grid Grid.Column="1"
              Margin="30">

            <!-- DASHBOARD -->

            <StackPanel x:Name="DashboardPanel">

                <TextBlock Text="User Dashboard"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"/>

                <TextBlock Text="Browse and borrow books"
                           Foreground="#94A3B8"
                           FontSize="16"
                           Margin="0,5,0,30"/>

                <WrapPanel>

                    <Border Background="#1E293B"
                            CornerRadius="18"
                            Padding="20"
                            Margin="0,0,20,20"
                            Width="250"
                            Height="140">

                        <StackPanel>

                            <TextBlock Text="Available Books"
                                       Foreground="#CBD5E1"
                                       FontSize="18"/>

                            <TextBlock x:Name="txtTotalBooks"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Margin="0,15,0,0"/>

                        </StackPanel>

                    </Border>

                    <Border Background="#1E293B"
                            CornerRadius="18"
                            Padding="20"
                            Width="250"
                            Height="140">

                        <StackPanel>

                            <TextBlock Text="Borrowed Books"
                                       Foreground="#CBD5E1"
                                       FontSize="18"/>

                            <TextBlock x:Name="txtBorrowedBooks"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Margin="0,15,0,0"/>

                        </StackPanel>

                    </Border>

                </WrapPanel>

            </StackPanel>

            <!-- BOOKS PANEL -->

            <Border x:Name="BooksPanel"
                    Visibility="Collapsed"
                    Background="#1E293B"
                    CornerRadius="18"
                    Padding="20">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT -->

                    <Grid Grid.Column="0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Books"
                                   Foreground="White"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <TextBox Grid.Row="1"
                                 x:Name="txtSearchBook"
                                 Height="38"
                                 Margin="0,0,0,15"
                                 FontSize="15"
                                 Padding="10,0,0,0"
                                 TextChanged="txtSearchBook_TextChanged"/>

                        <ListBox Grid.Row="2"
                                 x:Name="lstBooks"
                                 Background="#0F172A"
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="16"
                                 Margin="0,0,15,15"
                                 SelectionChanged="lstBooks_SelectionChanged"/>

                    </Grid>

                    <!-- RIGHT -->

                    <StackPanel Grid.Column="1"
                                Margin="20,0,0,0">

                        <TextBlock Text="Book Details"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Title"
                                   Foreground="#94A3B8"/>

                        <TextBlock x:Name="txtTitle"
                                   Foreground="White"
                                   FontSize="18"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Author"
                                   Foreground="#94A3B8"/>

                        <TextBlock x:Name="txtAuthor"
                                   Foreground="White"
                                   FontSize="18"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Category"
                                   Foreground="#94A3B8"/>

                        <TextBlock x:Name="txtCategory"
                                   Foreground="White"
                                   FontSize="18"
                                   Margin="0,5,0,15"/>

                        <TextBlock Text="Stock"
                                   Foreground="#94A3B8"/>

                        <TextBlock x:Name="txtStock"
                                   Foreground="White"
                                   FontSize="18"
                                   Margin="0,5,0,30"/>

                        <Button x:Name="btnBorrowBook"
                                Content="Borrow Book"
                                Height="40"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                Click="btnBorrowBook_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

            <!-- BORROWED PANEL -->

            <Border x:Name="BorrowedPanel"
                    Visibility="Collapsed"
                    Background="#1E293B"
                    CornerRadius="18"
                    Padding="20">

                <StackPanel>

                    <TextBlock Text="My Borrowed Books"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="Bold"
                               Margin="0,0,0,20"/>

                    <ListBox x:Name="lstBorrowedBooks"
                             Background="#0F172A"
                             Foreground="White"
                             BorderThickness="0"
                             FontSize="16"/>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Window>